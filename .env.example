# ============ Configuración de Base de Datos ============
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# Ejemplo para desarrollo local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chronoguard_dev

# ============ Seguridad ============
# Genera una clave secreta fuerte con: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32

# ============ Ambiente ============
ENVIRONMENT=development

# ============ Configuración del Motor de Inactividad ============
DEFAULT_PING_INTERVAL_DAYS=7
DEFAULT_TRIGGER_AFTER_DAYS=30

# ============ Configuración de Emails ============
# Para desarrollo, puedes usar un servicio como MailTrap o SendGrid
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USER=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
EMAILS_FROM_EMAIL=noreply@chronoguard.com

# ============ Seguridad de Cuenta ============
# Número máximo de intentos de login fallidos antes de bloquear la cuenta
MAX_LOGIN_ATTEMPTS=5
# Minutos que la cuenta permanece bloqueada tras exceder intentos
ACCOUNT_LOCKOUT_MINUTES=15
# Máximo de requests por minuto por IP (rate limiting)
RATE_LIMIT_PER_MINUTE=10

# ============ CORS ============
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
